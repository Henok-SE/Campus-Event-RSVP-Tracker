PORT=5050
MONGODB_URI=mongodb://127.0.0.1:27017/eventDB
JWT_SECRET=dev-jwt-secret-change-me
FRONTEND_ORIGINS=http://localhost:5173
# Optional in local dev. Set in production so backend can build absolute upload URLs behind reverse proxies.
PUBLIC_API_BASE_URL=http://localhost:5050
IMAGE_STORAGE=local
# Set IMAGE_STORAGE=cloudinary in production and provide these values.
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_FOLDER=campus-event-rsvp/events
